# LifeQuest OS — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- AI (required to enable the coach + voice) ---
# Your OpenAI API key is the ONLY secret. Model ids are NOT secrets and live
# in code at src/config/ai.ts (COACH_MODEL, REALTIME_VOICE_MODEL).
OPENAI_API_KEY=
# Optional tuning.
OPENAI_MAX_TOKENS=800
OPENAI_TIMEOUT_MS=30000

# --- Nutrition: food-photo + restaurant recommender (Milestone 2) ---
# Google Places (nearby restaurants). Server-side only.
GOOGLE_PLACES_API_KEY=
# Optional grounded-nutrition database (Nutritionix or USDA FoodData Central).
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# --- Cloud backup/sync: Supabase ---
# Only these two are needed (both safe in the browser; Row Level Security
# enforces per-user access). Find them in Supabase: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Integrations: Health Connect / glucose / BP (Milestone 5) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
