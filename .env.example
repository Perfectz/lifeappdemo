# LifeQuest OS — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- AI (required to enable the coach + voice) ---
# Your OpenAI API key is the ONLY secret. Model ids are NOT secrets and live
# in code at src/config/ai.ts (COACH_MODEL, REALTIME_VOICE_MODEL).
OPENAI_API_KEY=
# Optional tuning.
OPENAI_MAX_TOKENS=800
OPENAI_TIMEOUT_MS=30000

# --- Nutrition: food-photo + restaurant recommender (Milestone 2) ---
# Google Places (nearby restaurants). Server-side only.
GOOGLE_PLACES_API_KEY=
# Optional grounded-nutrition database (Nutritionix or USDA FoodData Central).
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# --- Cloud backup/sync + API auth: Supabase ---
# Only these two are needed (both safe in the browser; Row Level Security
# enforces per-user access). Find them in Supabase: Project Settings → API.
# They also power the server-side API guard (src/server/auth/requireUser.ts):
# when Supabase is configured, the AI/food/realtime routes require a signed-in
# approved member. Defaults for the production project are baked into
# src/lib/supabase/config.ts; these env vars override them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google integrations: Gmail + Health Connect ---
# Gmail uses a Google Cloud Web OAuth client. Enable the Gmail API and register:
#   Local:      http://localhost:3000/api/integrations/gmail/callback
#   Production: https://YOUR_DOMAIN/api/integrations/gmail/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Phone reminders (feature-flagged, OFF by default). See PUSH_SETUP.md ---
# Set to "true" to surface the Phone Reminders panel and arm the cron job.
NEXT_PUBLIC_PUSH_ENABLED=
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Service-role key (server-only) — the cron reads all users' synced data.
SUPABASE_SERVICE_ROLE_KEY=
# 32+ random characters used to encrypt OAuth refresh tokens at rest.
INTEGRATION_ENCRYPTION_KEY=
# Optional canonical origin used to build the OAuth callback URL.
APP_URL=http://localhost:3000
# Shared secret Vercel Cron sends as a Bearer token to authorize the cron route.
CRON_SECRET=
