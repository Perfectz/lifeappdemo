# LifeQuest OS — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# --- AI coach (required to enable the coach) ---
# Your OpenAI API key (server-side only; never exposed to browser code).
OPENAI_API_KEY=
# Exact model id your account can call, e.g. gpt-5.5 / gpt-4.1 / gpt-4o.
# Leave unset to use the in-code default.
OPENAI_MODEL=
# Optional tuning.
OPENAI_MAX_TOKENS=800
OPENAI_TIMEOUT_MS=30000

# --- Nutrition: food-photo + restaurant recommender (Milestone 2) ---
# Google Places (nearby restaurants). Server-side only.
GOOGLE_PLACES_API_KEY=
# Optional grounded-nutrition database (Nutritionix or USDA FoodData Central).
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# --- Backend: Supabase (Milestone 4) ---
# Public values are safe in the browser; the service-role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Integrations: Health Connect / glucose / BP (Milestone 5) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
